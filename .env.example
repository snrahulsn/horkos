# Postgres connection (Supabase: Project Settings → Database → Connection string)
DATABASE_URL=postgres://user:pass@host:5432/horkos

# Server
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=
DONATION_URL=

# Supabase Auth (operator OAuth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
AUTH_GITHUB_ENABLED=false
AUTH_GOOGLE_ENABLED=false

# Trusted proof ingestion. PROOF_DATABASE_URL must authenticate as the
# dedicated horkos_proof_ingestor database role created by migration 003.
PROOF_DATABASE_URL=
PROOF_INGEST_SECRET=
GITHUB_WEBHOOK_SECRET=

# Merkle root signing key (hex-encoded Ed25519 seed; generate: openssl rand -hex 32)
MERKLE_SIGNING_SEED=
